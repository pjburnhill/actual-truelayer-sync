# Immutable image tag or digest published by the trusted repository workflow
ACTUAL_TRUELAYER_SYNC_IMAGE=ghcr.io/pjburnhill/actual-truelayer-sync:sha-[COMMIT_SHA]

# URL of your self-hosted Actual Budget instance (e.g. http://192.168.1.10:5006)
ACTUAL_SERVER_URL=

# Exactly one protected Actual credential file, with mode 0600
ACTUAL_SESSION_TOKEN_FILE=/run/secrets/actual-session-token
# ACTUAL_PASSWORD_FILE=/run/secrets/actual-password

# Protected file containing the budget Sync ID, with mode 0600
ACTUAL_SYNC_ID_FILE=/run/secrets/actual-sync-id

# TrueLayer developer credentials — from https://console.truelayer.com/
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET_FILE=/run/secrets/truelayer-client-secret

# How often to run the sync, in standard cron syntax.
# If not set, the sync runs once on startup and then exits.
# Example: every 6 hours at minute 17
# CRON_SCHEDULE=17 */6 * * *

# Timezone for the cron schedule (uses IANA timezone names).
# If not set, UTC is used.
# TZ=Europe/London

# Set to "text" for human-readable logs instead of JSON (useful for local development).
# LOG_FORMAT=text

# Set to "true" to enable verbose Actual Budget API logging.
# DEBUG=true
